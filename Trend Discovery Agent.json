      "parameters": {
        "jsCode": "const input = $json; \nlet text = \"\";\nif (input.content?.parts?.[0]?.text) {\n  text = input.content.parts[0].text;\n}\nelse if (input.text) {\n  text = input.text;\n}\nelse if (input.content) {\n  text = input.content;\n}\ntext = String(text)\n  .replace(/\\*\\*/g, \"\")\n  .replace(/\\n{2,}/g, \"\\n\")\n  .trim();\nreturn [{ json: { output: text } }];"
