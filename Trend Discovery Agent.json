    {
      "parameters": {
        "jsCode": "return items.map(item => {\n  let raw = \"\";\n  try {\n    if (item.json.content && item.json.content.parts && item.json.content.parts[0]) {\n      raw = item.json.content.parts[0].text;\n    } else {\n      raw = item.json.output || item.json.text || \"\";\n    }\n  } catch (err) {\n    raw = \"\";\n  }\n  raw = raw.replace(/```json|```/gi, \"\").trim();\n  let parsed;\n  try {\n    parsed = JSON.parse(raw);\n  } catch (e) {\n    parsed = { is_trend: false };\n  }\n  return {\n    json: {\n      isTrendQuery: parsed.is_trend === true,\n      topic: parsed.core_topic || \"Unknown Topic\",\n      simpleAnswer: parsed.answer\n    }\n  };\n});"
      },
